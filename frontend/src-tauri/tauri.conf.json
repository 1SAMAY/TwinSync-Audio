{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TwinSync Audio",
  "version": "0.1.0",
  "identifier": "com.twinsync.audio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TwinSync Audio",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "publisher": "TwinSync Audio",
    "shortDescription": "Dual Bluetooth speaker synchronization",
    "longDescription": "TwinSync Audio plays Windows system audio through two selected speakers with local latency compensation."
  }
}

