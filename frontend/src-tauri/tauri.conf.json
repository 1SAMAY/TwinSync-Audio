{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TwinSync Audio",
  "version": "0.1.1",
  "identifier": "io.github.1samay.twinsync-audio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TwinSync Audio",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "SAMAY",
    "copyright": "Copyright (c) 2026 SAMAY DUDHREJIYA",
    "icon": ["icons/icon.ico"],
    "resources": {
      "../../backend-dist/twinsync-backend.exe": "backend/twinsync-backend.exe"
    },
    "shortDescription": "Dual Bluetooth speaker synchronization",
    "longDescription": "TwinSync Audio routes Windows audio through two selected speakers with local latency compensation.",
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "startMenuFolder": "TwinSync Audio"
      }
    }
  }
}
